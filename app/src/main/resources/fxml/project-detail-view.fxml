<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.localprojectmanager.ui.ProjectDetailViewController"
            styleClass="page-card">
    <top>
        <Button text="← 返回项目列表" onAction="#goBack" styleClass="back-button">
            <BorderPane.margin>
                <Insets top="24" right="32" bottom="8" left="24"/>
            </BorderPane.margin>
        </Button>
    </top>
    <center>
        <ScrollPane fitToWidth="true" pannable="true" styleClass="project-scroll">
            <content>
                <VBox spacing="18">
                    <VBox spacing="6">
                        <HBox alignment="CENTER_LEFT" spacing="12">
                            <Label fx:id="displayNameLabel" styleClass="welcome-title"/>
                            <Label fx:id="pathStatusLabel"/>
                        </HBox>
                        <Label fx:id="directoryNameLabel" styleClass="project-meta"/>
                        <Label fx:id="pathLabel" wrapText="true" styleClass="project-card-path"/>
                    </VBox>

                    <VBox spacing="14" styleClass="detail-panel">
                        <Label text="快捷操作" styleClass="detail-title"/>
                        <FlowPane hgap="10" vgap="10">
                            <Button fx:id="openProjectButton" text="打开项目"
                                    onAction="#openProject" disable="true"/>
                            <Button text="使用其他 IDE" onAction="#openWithOtherIde"/>
                            <Button fx:id="openExplorerButton" text="在资源管理器中打开"
                                    onAction="#openInExplorer" disable="true"/>
                            <Button fx:id="openTerminalButton" text="在终端中打开"
                                    onAction="#openInTerminal" disable="true"/>
                        </FlowPane>
                        <HBox alignment="CENTER_LEFT" spacing="8">
                            <Label text="默认 IDE" styleClass="detail-key"/>
                            <ComboBox fx:id="defaultIdeChoice" promptText="选择默认 IDE"
                                      prefWidth="260" accessibleText="默认 IDE"/>
                            <Button text="保存" onAction="#saveDefaultIde"/>
                            <Button fx:id="clearDefaultIdeButton" text="清除"
                                    onAction="#clearDefaultIde"/>
                        </HBox>
                        <Label fx:id="ideStatusLabel" wrapText="true" styleClass="status-text"/>
                    </VBox>

                    <VBox spacing="12" styleClass="detail-panel">
                        <HBox alignment="CENTER_LEFT" spacing="12">
                            <Label text="Git 状态" styleClass="detail-title"/>
                            <Button fx:id="refreshGitButton" text="刷新当前状态"
                                    onAction="#refreshGitStatus" disable="true"/>
                            <Button fx:id="fetchButton" text="检查远程更新"
                                    onAction="#fetchRemote" disable="true"/>
                            <Button fx:id="pullButton" text="Pull"
                                    onAction="#pullProject" disable="true"/>
                        </HBox>
                        <HBox spacing="8">
                            <Label text="当前分支" styleClass="detail-key"/>
                            <Label fx:id="currentBranchLabel" text="待刷新" styleClass="detail-value"/>
                        </HBox>
                        <HBox spacing="8">
                            <Label text="本地修改" styleClass="detail-key"/>
                            <Label fx:id="modificationsLabel" text="待刷新" styleClass="detail-value"/>
                        </HBox>
                        <HBox spacing="8">
                            <Label text="最近提交" styleClass="detail-key"/>
                            <Label fx:id="latestCommitLabel" text="待刷新" styleClass="detail-value"/>
                        </HBox>
                        <HBox spacing="8">
                            <Label text="远程仓库" styleClass="detail-key"/>
                            <Label fx:id="remoteUrlLabel" text="待刷新" wrapText="true"
                                   styleClass="detail-value"/>
                        </HBox>
                        <Label fx:id="gitStatusLabel" text="尚无 Git 状态缓存。"
                               styleClass="status-text"/>
                        <Label fx:id="lastOperationLabel" text="最近操作：无"
                               styleClass="status-text"/>
                        <HBox alignment="CENTER_LEFT" spacing="8">
                            <Label text="Pull 策略" styleClass="detail-key"/>
                            <ComboBox fx:id="pullStrategyChoice" prefWidth="180"/>
                            <Button text="保存策略" onAction="#savePullStrategy"/>
                        </HBox>
                    </VBox>

                    <VBox spacing="10" styleClass="detail-panel">
                        <Label text="分支" styleClass="detail-title"/>
                        <TextField fx:id="branchSearchField" promptText="搜索分支名称"
                                   accessibleText="搜索分支名称"/>
                        <HBox spacing="16">
                            <VBox spacing="6" HBox.hgrow="ALWAYS">
                                <Label text="本地分支" styleClass="detail-key"/>
                                <ListView fx:id="localBranchesList" prefHeight="120"/>
                                <Button fx:id="switchLocalBranchButton" text="切换到所选分支"
                                        onAction="#switchLocalBranch" disable="true"/>
                            </VBox>
                            <VBox spacing="6" HBox.hgrow="ALWAYS">
                                <Label text="远程分支" styleClass="detail-key"/>
                                <ListView fx:id="remoteBranchesList" prefHeight="120"/>
                                <Button fx:id="trackRemoteBranchButton" text="创建并切换跟踪分支"
                                        onAction="#trackRemoteBranch" disable="true"/>
                            </VBox>
                        </HBox>
                        <Label fx:id="branchStatusLabel" text="尚未读取分支。"
                               styleClass="status-text"/>
                    </VBox>

                    <HBox spacing="10">
                        <Button text="重命名" onAction="#renameProject"/>
                        <Button text="重新指定路径" onAction="#relocateProject"/>
                        <Button text="从软件中移除" onAction="#removeProject"/>
                    </HBox>
                    <padding>
                        <Insets top="16" right="40" bottom="40" left="40"/>
                    </padding>
                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>
