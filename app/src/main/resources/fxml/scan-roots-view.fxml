<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.localprojectmanager.ui.ScanRootsViewController"
      alignment="TOP_CENTER" spacing="18" styleClass="page-card">
    <HBox alignment="CENTER_LEFT" spacing="14" maxWidth="Infinity">
        <Button text="← 返回" onAction="#goBack" styleClass="back-button">
        </Button>
        <Label text="选择扫描目录" styleClass="welcome-title"/>
    </HBox>
    <VBox spacing="14" maxWidth="760" styleClass="detail-panel" VBox.vgrow="ALWAYS">
            <Label text="将在以下目录中查找 Git 项目。你可以一次添加多个位置。"
                   wrapText="true" styleClass="section-description"/>
            <ListView fx:id="scanRootsList" prefHeight="260" styleClass="scan-root-list"
                      VBox.vgrow="ALWAYS">
                <placeholder>
                    <Label text="尚未添加扫描目录" styleClass="empty-text"/>
                </placeholder>
            </ListView>
            <HBox alignment="CENTER_LEFT" spacing="12">
                <Button fx:id="addButton" text="+ 添加目录" onAction="#addDirectory"/>
                <Button fx:id="removeButton" text="移除所选目录" onAction="#removeSelected"/>
                <Region HBox.hgrow="ALWAYS"/>
            </HBox>
            <CheckBox fx:id="defaultIgnoreRulesCheckBox" text="使用默认忽略规则"/>
            <Label fx:id="messageLabel" wrapText="true" styleClass="status-text"/>
            <HBox alignment="CENTER_RIGHT">
                <Button fx:id="startScanButton" text="开始扫描" onAction="#startScan"
                        defaultButton="true" minWidth="128" styleClass="primary-button"/>
            </HBox>
    </VBox>
    <padding>
        <Insets top="28" right="32" bottom="32" left="32"/>
    </padding>
</VBox>
